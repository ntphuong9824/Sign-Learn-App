# =============================================================================
# Sign Learn - Environment Configuration Template
# =============================================================================
# Copy this file to .env and configure values for your environment
# cp .env.example .env

# =============================================================================
# Spring Profile
# =============================================================================
# dev: Uses H2 in-memory database (no PostgreSQL required)
# prod: Uses PostgreSQL database
SPRING_PROFILES_ACTIVE=dev

# =============================================================================
# Database Configuration (only for prod profile)
# =============================================================================
POSTGRES_USER=signlearn
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=signlearn_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# =============================================================================
# Backend Configuration
# =============================================================================
SERVER_PORT=8080
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# =============================================================================
# External APIs
# =============================================================================
SIGN_MT_API_URL=https://sign.mt
FIREBASE_FUNCTIONS_URL=https://us-central1-sign-mt.cloudfunctions.net

# =============================================================================
# Firebase AppCheck Token
# =============================================================================
# Required for sign.mt API authentication
# Get this from Firebase AppCheck or use a test token for development
APP_CHECK_TOKEN=

# =============================================================================
# Application URLs
# =============================================================================
API_BASE_URL=http://localhost:8080/api/v1
PUBLIC_APP_URL=http://localhost:5173
