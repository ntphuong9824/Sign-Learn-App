# =============================================================================
# Frontend Environment Configuration
# =============================================================================
# Copy this file to .env and configure values for your environment
# cp .env.example .env

# =============================================================================
# Spring Boot Backend API URL
# =============================================================================
# Default: /api/v1/translate (uses Vite proxy)
# For production, use full URL: http://your-backend-url/api/v1/translate
VITE_SPRING_BOOT_API_URL=/api/v1/translate

# =============================================================================
# Firebase App Check (React)
# =============================================================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_RECAPTCHA_SITE_KEY=

# Optional, local debugging only. Do not set in production.
# VITE_APP_CHECK_DEBUG_TOKEN=true
